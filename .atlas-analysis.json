  "keyFeatures": [
    "macOS Tahoe (26.5+) native Finder replacement",
    "Local-first SQLite library — no cloud sign-up required",
    "Cloud storage integration: S3, Google Drive, OneDrive, Dropbox, WebDAV",
    "Automatic detection of iCloud, GDrive, OneDrive, Dropbox mounts",
    "Core Spotlight and Quick Look integration",
    "Finder Sync Extension for real-time status overlays",
    "GPU-accelerated thumbnail pipeline via VideoToolbox and Metal",
    "Token-driven theme system with dark/light mode",
    "JSON-RPC 2.0 IPC over Unix socket for extensibility",
    "Full Disk Access, Services menu, and file promise drag-out"
  ],
